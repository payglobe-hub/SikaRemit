# ============================================================================
# SikaRemit Backend — Environment Variables
# Copy this file to .env for local development
# For production (GCP Cloud Run), use GCP Secret Manager instead
# ============================================================================

# =========================
# CORE DJANGO
# =========================
SECRET_KEY=your-django-secret-key-change-this-in-production
DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================
# DATABASE
# =========================
# Set to false to use PostgreSQL instead of SQLite
DJANGO_USE_SQLITE=true
# PostgreSQL connection (used when DJANGO_USE_SQLITE=false)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sikaremit
# Or individual vars:
# DB_NAME=sikaremit
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# =========================
# REDIS (Celery broker + cache + WebSocket channels)
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# STRIPE (Card payments, Apple Pay, Google Pay, Subscriptions)
# =========================
# Test keys start with sk_test_ / pk_test_
# Live keys start with sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# =========================
# MTN MOBILE MONEY (MoMo)
# =========================
# Sandbox URL: https://sandbox.momodeveloper.mtn.com
# Production URL: https://proxy.momoapi.mtn.com
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_API_KEY=your-mtn-momo-api-key
MTN_MOMO_API_SECRET=your-mtn-momo-api-secret
MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_WEBHOOK_SECRET=your-mtn-webhook-secret

# =========================
# AIRTELTIGO MONEY
# =========================
AIRTEL_API_KEY=your-airtel-api-key
AIRTEL_API_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your-airtel-client-id
AIRTEL_CLIENT_SECRET=your-airtel-client-secret
AIRTEL_WEBHOOK_SECRET=your-airtel-webhook-secret

# =========================
# TELECEL CASH
# =========================
TELECEL_API_KEY=your-telecel-api-key
TELECEL_API_URL=https://api.telecel.com
TELECEL_MERCHANT_ID=your-telecel-merchant-id
TELECEL_WEBHOOK_SECRET=your-telecel-webhook-secret

# =========================
# G-MONEY (GCB Bank Ghana)
# =========================
G_MONEY_API_KEY=your-g-money-api-key
G_MONEY_API_SECRET=your-g-money-api-secret
G_MONEY_API_URL=https://api.gcb.com.gh/nexus
G_MONEY_WEBHOOK_SECRET=your-g-money-webhook-secret

# =========================
# PAYMENT CALLBACKS
# =========================
# Must be your production API domain for webhooks to work
PAYMENT_CALLBACK_URL=http://localhost:8000/api/v1/payments/webhooks

# =========================
# EMAIL (SendGrid)
# =========================
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@sikaremit.com
# Fallback SMTP (if not using SendGrid backend)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# =========================
# SMS
# =========================
# Africa's Talking (default)
SMS_PROVIDER=africastalking
AFRICASTALKING_USERNAME=your-africastalking-username
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_SENDER_ID=SikaRemit

# Twilio (alternative / international)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =========================
# GOOGLE OAUTH
# =========================
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# =========================
# EXCHANGE RATES
# =========================
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/

# =========================
# MONITORING
# =========================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1
RELEASE_VERSION=dev

# =========================
# MFA
# =========================
MFA_ISSUER_NAME=SikaRemit

# =========================
# COMPLIANCE (Bank of Ghana)
# =========================
COMPLIANCE_REPORTING_ENABLED=False
BOG_API_ENDPOINT=https://api.bog.gov.gh/remittances
BOG_API_KEY=your-bog-api-key
BOG_REPORTING_ENABLED=False

# =========================
# GCP (Production only — not needed for local dev)
# =========================
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
