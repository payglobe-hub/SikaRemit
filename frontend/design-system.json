{
  "name": "SikaRemit Unified Design System",
  "version": "1.0.0",
  "description": "Unified design system for Customer and Merchant web applications",

  "colorPalette": {
    "primary": {
      "50": "#eff6ff",
      "100": "#dbeafe",
      "200": "#bfdbfe",
      "300": "#93c5fd",
      "400": "#60a5fa",
      "500": "#3b82f6",
      "600": "#2563eb",
      "700": "#1d4ed8",
      "800": "#1e40af",
      "900": "#1e3a8a",
      "950": "#172554"
    },
    "secondary": {
      "50": "#f0fdf4",
      "100": "#dcfce7",
      "200": "#bbf7d0",
      "300": "#86efac",
      "400": "#4ade80",
      "500": "#22c55e",
      "600": "#16a34a",
      "700": "#15803d",
      "800": "#166534",
      "900": "#14532d",
      "950": "#052e16"
    },
    "accent": {
      "50": "#faf5ff",
      "100": "#f3e8ff",
      "200": "#e9d5ff",
      "300": "#d8b4fe",
      "400": "#c084fc",
      "500": "#a855f7",
      "600": "#9333ea",
      "700": "#7c3aed",
      "800": "#6b21a8",
      "900": "#581c87",
      "950": "#3b0764"
    },
    "neutral": {
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a",
      "950": "#020617"
    },
    "semantic": {
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#3b82f6"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": ["Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"],
      "mono": ["JetBrains Mono", "Monaco", "Consolas", "Liberation Mono", "Courier New", "monospace"]
    },
    "fontSize": {
      "xs": ["0.75rem", { "lineHeight": "1rem" }],
      "sm": ["0.875rem", { "lineHeight": "1.25rem" }],
      "base": ["1rem", { "lineHeight": "1.5rem" }],
      "lg": ["1.125rem", { "lineHeight": "1.75rem" }],
      "xl": ["1.25rem", { "lineHeight": "1.75rem" }],
      "2xl": ["1.5rem", { "lineHeight": "2rem" }],
      "3xl": ["1.875rem", { "lineHeight": "2.25rem" }],
      "4xl": ["2.25rem", { "lineHeight": "2.5rem" }],
      "5xl": ["3rem", { "lineHeight": "1" }],
      "6xl": ["3.75rem", { "lineHeight": "1" }]
    },
    "fontWeight": {
      "thin": "100",
      "extralight": "200",
      "light": "300",
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "extrabold": "800",
      "black": "900"
    }
  },

  "spacing": {
    "scale": {
      "0": "0",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem",
      "40": "10rem",
      "48": "12rem",
      "56": "14rem",
      "64": "16rem"
    }
  },

  "borderRadius": {
    "none": "0",
    "sm": "0.125rem",
    "base": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "base": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "2xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
    "inner": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)",
    "none": "0 0 #0000"
  },

  "components": {
    "button": {
      "variants": {
        "primary": {
          "background": "primary-600",
          "color": "white",
          "hover": "primary-700",
          "padding": "0.5rem 1rem",
          "borderRadius": "md"
        },
        "secondary": {
          "background": "secondary-600",
          "color": "white",
          "hover": "secondary-700",
          "padding": "0.5rem 1rem",
          "borderRadius": "md"
        },
        "outline": {
          "background": "transparent",
          "color": "primary-600",
          "border": "1px solid primary-600",
          "hover": "primary-50",
          "padding": "0.5rem 1rem",
          "borderRadius": "md"
        },
        "ghost": {
          "background": "transparent",
          "color": "neutral-700",
          "hover": "neutral-100",
          "padding": "0.5rem 1rem",
          "borderRadius": "md"
        }
      },
      "sizes": {
        "sm": { "padding": "0.25rem 0.5rem", "fontSize": "sm" },
        "md": { "padding": "0.5rem 1rem", "fontSize": "base" },
        "lg": { "padding": "0.75rem 1.5rem", "fontSize": "lg" }
      }
    },

    "card": {
      "background": "white",
      "border": "1px solid neutral-200",
      "borderRadius": "lg",
      "padding": "1.5rem",
      "shadow": "sm"
    },

    "input": {
      "background": "white",
      "border": "1px solid neutral-300",
      "borderRadius": "md",
      "padding": "0.5rem 0.75rem",
      "focus": {
        "border": "primary-500",
        "ring": "primary-500"
      }
    },

    "layout": {
      "container": {
        "maxWidth": "1280px",
        "padding": "1rem",
        "responsive": {
          "sm": "2rem",
          "md": "3rem",
          "lg": "4rem"
        }
      },
      "sidebar": {
        "width": "16rem",
        "collapsed": "4rem",
        "background": "white",
        "border": "neutral-200"
      },
      "header": {
        "height": "4rem",
        "background": "white",
        "border": "neutral-200"
      }
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "zIndex": {
    "dropdown": "1000",
    "sticky": "1020",
    "fixed": "1030",
    "modal-backdrop": "1040",
    "modal": "1050",
    "popover": "1060",
    "tooltip": "1070"
  }
}
