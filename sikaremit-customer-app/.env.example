# SikaRemit Customer App - Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
EXPO_PUBLIC_API_URL=https://api.sikaremit.com

# App Configuration
EXPO_PUBLIC_APP_NAME=SikaRemit
EXPO_PUBLIC_APP_VERSION=1.0.0

# Stripe Configuration (for card payments)
EXPO_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key_here

# Sentry Error Tracking (Optional)
EXPO_PUBLIC_SENTRY_DSN=

# Environment
EXPO_PUBLIC_ENVIRONMENT=production
