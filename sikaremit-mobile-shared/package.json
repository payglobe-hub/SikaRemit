{
  "name": "@sikaremit/mobile-shared",
  "version": "1.0.0",
  "description": "Shared library for SikaRemit mobile applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/ui": {
      "types": "./dist/components/ui/index.d.ts",
      "default": "./dist/components/ui/index.js"
    },
    "./components/qr": {
      "types": "./dist/components/qr/index.d.ts",
      "default": "./dist/components/qr/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./constants/api": {
      "types": "./dist/constants/api.d.ts",
      "default": "./dist/constants/api.js"
    },
    "./constants/theme": {
      "types": "./dist/constants/theme.d.ts",
      "default": "./dist/constants/theme.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "react-native",
    "expo",
    "typescript",
    "fintech",
    "mobile",
    "shared-library",
    "sikaremit"
  ],
  "author": "SikaRemit Team",
  "license": "MIT",
  "peerDependencies": {
    "@expo/vector-icons": ">=13.0.0",
    "expo": ">=47.0.0",
    "expo-device": ">=5.0.0",
    "expo-location": ">=15.0.0",
    "expo-notifications": ">=0.17.0",
    "expo-linking": ">=4.0.0",
    "@react-native-async-storage/async-storage": ">=1.17.0",
    "@react-native-community/netinfo": ">=9.3.0",
    "@react-navigation/native": ">=6.1.0",
    "@react-navigation/native-stack": ">=6.9.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "axios": "^1.6.0",
    "expo-barcode-scanner": "~12.0.0",
    "expo-camera": "~13.0.0",
    "expo-haptics": "~12.0.0",
    "expo-linear-gradient": "~12.0.0",
    "expo-secure-store": "~12.0.0",
    "react-native-qrcode-svg": "^6.2.0",
    "react-native-svg": "^14.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@react-native-community/netinfo": "^9.3.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.0.0",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sikaremit/mobile-shared.git"
  },
  "bugs": {
    "url": "https://github.com/sikaremit/mobile-shared/issues"
  },
  "homepage": "https://github.com/sikaremit/mobile-shared#readme"
}
